# PyPitch environment example
# Copy this file to .env and replace placeholder values.

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong random value, for example:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
PYPITCH_SECRET_KEY=replace-with-random-secret

# Docker compose compatibility variable.
# Keep this value the same as PYPITCH_SECRET_KEY.
SECRET_KEY=replace-with-same-value-as-PYPITCH_SECRET_KEY

# API key authentication (recommended true for all non-test environments)
PYPITCH_API_KEY_REQUIRED=true

# Comma-separated API keys, no spaces.
# Example: key-one,key-two
PYPITCH_API_KEYS=replace-with-one-or-more-api-keys

# -----------------------------------------------------------------------------
# API / Network
# -----------------------------------------------------------------------------
PYPITCH_ENV=development
PYPITCH_API_HOST=0.0.0.0
PYPITCH_API_PORT=8000

# Comma-separated origins. Empty means browsers cannot call API cross-origin.
PYPITCH_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Comma-separated allowed Host headers.
PYPITCH_ALLOWED_HOSTS=localhost,127.0.0.1

# Set true only when running behind a trusted reverse proxy.
PYPITCH_BEHIND_PROXY=false

# Keep disabled unless you explicitly need ad-hoc SQL endpoint.
PYPITCH_ANALYZE_ENABLED=false

# -----------------------------------------------------------------------------
# Data / Runtime
# -----------------------------------------------------------------------------
PYPITCH_DATA_DIR=./data
PYPITCH_DB_THREADS=4
PYPITCH_DB_MEMORY=2GB
PYPITCH_CACHE_TTL=3600
CRICSHEET_URL=https://cricsheet.org/downloads/ipl_json.zip

# -----------------------------------------------------------------------------
# Docker compose extras
# -----------------------------------------------------------------------------
DB_PASSWORD=replace-with-strong-postgres-password
GRAFANA_PASSWORD=replace-with-strong-grafana-password

# -----------------------------------------------------------------------------
# Optional plugin controls (advanced)
# -----------------------------------------------------------------------------
# Comma-separated allowed module prefixes for plugin loading.
PYPITCH_PLUGIN_ALLOWLIST=

# Comma-separated plugin module paths.
# In production, prefer leaving this empty.
PYPITCH_PLUGINS=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO